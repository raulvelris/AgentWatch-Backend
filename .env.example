# =============================================================================
# AgentWatch Backend - variables de entorno
# Copiar a .env (gitignorado) y ajustar. Todos los valores tienen default:
# el backend levanta en local sin crear este archivo.
# =============================================================================

# --- Módulo 2 (Despliegue / CI-CD) ----------------------------------------
# Base de datos del historial de versiones, promociones, despliegues y
# notificaciones. SQLite embebido por defecto (archivo en la raíz del repo,
# gitignorado). Para PostgreSQL: postgresql+psycopg://user:pass@host/db
#DATABASE_URL=sqlite:///./agentwatch.db

# Orígenes CORS permitidos, separados por coma. Para probar desde un celular
# en la misma red WiFi, agregar la IP local de tu PC (cmd: ipconfig →
# "Dirección IPv4"), por ejemplo:
#CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081,http://192.168.1.49:5173,http://192.168.1.49:8081

# Clave Fernet para cifrar las variables de entorno por ambiente (RF06/ADR-02.6,
# EC-02.5). Sin ella, la clave se genera efímera por proceso y los secretos NO
# sobreviven un reinicio del backend: el GET de variables responde 503. En
# producción, definirla siempre. Generar una con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#ENVVARS_KEY=

# --- Módulo 5 (Trazabilidad / Neo4j, RF17-RF20) -----------------------------
# Opcionales. Sin NEO4J_URI, los endpoints /api/v1/traces|audit|metrics|
# executions responden 503 "Neo4j no configurado" y el resto de la API
# funciona normal.
#NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
#NEO4J_USER=neo4j
#NEO4J_PASSWORD=changeme
#NEO4J_DATABASE=neo4j

# --- Módulo 4 (Seguridad / JWT) ---------------------------------------------
# Clave de firma del camino SEGURO de JWT. Hoy autenticacion_serv.py aún la
# tiene hardcodeada (pendiente de Emilio leerla de aquí); el default replica
# ese valor para no invalidar tokens. La CLAVE_DEBIL del camino vulnerable
# de la demo de pen-testing NO se configura: es deliberadamente insegura.
#JWT_SECRET=agente123
